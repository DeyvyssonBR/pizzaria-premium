<script>
    function sendWhatsapp(padrao = true) {
        // fbq('track', 'Contact');

        // const isWeekend = [0, 6].includes(new Date().getDay());

        // if (isWeekend) {
        //     window.location.href = './whatsapp.html';
        //     return;
        // }

        // const urlParams = new URLSearchParams(window.location.search);

        // let txt = padrao
        //     ? (urlParams.has('v')
        //         ? 'Oi, gostaria de saber mais sobre o Zaper Menu'
        //         : 'Olá, gostaria de saber mais sobre o Zaper Menu'
        //     )
        //     : document.getElementById('mensagem').value;

        // window.open('https://api.whatsapp.com/send?phone=5549989085829&text=' + encodeURIComponent(txt));

        if (urlParams.has('rmkt')) {
            const txt = 'Oi, tenho interesse no Zaper Menu';
            window.open('https://api.whatsapp.com/send?phone=5549989085829&text=' + encodeURIComponent(txt));
            return;
        }

        const ad = urlParams.get('ad') || '';
        window.location.href = './whatsapp.html?ad=' + ad;
    }

    function openDemonstracao(modelo) {
        window.open(`https://app.zapermenu.com.br/modelo-${modelo}`, '_blank');
    }

    function animateIcon() {
        whatsIcon.animate(
            [
                { 'right': '15px' },
                { 'right': '20px' },
                { 'right': '15px' },
                { 'right': '10px' },
                { 'right': '15px' },
            ],
            {
                duration: 80,
                iterations: 8
            }
        );
    }

    function changeWhatsIcon() {
        const whatsIcon = document.querySelector('#whatsIcon');
        whatsIcon.src = 'src/images/zap2.png';

        animateIcon();
        setInterval(() => animateIcon(), 12000);
    }

    setTimeout(() => changeWhatsIcon(), 8000);
</script>
