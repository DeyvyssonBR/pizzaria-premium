# =============================================================================
# Mercado Pago — copie para .env.local e preencha.
# NUNCA commite .env.local / .env com tokens reais.
# =============================================================================
#
# Alternar ambiente = só trocar estas variáveis (e reiniciar o server / redeploy).
# Não é necessário alterar código-fonte.
#
# Desenvolvimento (Sandbox):
#   MERCADOPAGO_ENV=sandbox
#   tokens que começam com TEST-...
#
# Produção:
#   MERCADOPAGO_ENV=production
#   tokens que começam com APP_USR-...
# =============================================================================

MERCADOPAGO_PUBLIC_KEY=TEST-sua-public-key-aqui
MERCADOPAGO_ACCESS_TOKEN=TEST-seu-access-token-aqui
MERCADOPAGO_ENV=sandbox

# Opcional — validação de webhook IPN
# MERCADOPAGO_WEBHOOK_SECRET=seu-segredo-do-painel-mp

# -----------------------------------------------------------------------------
# Aliases legados (ainda funcionam se os nomes novos não estiverem definidos):
#   MP_PUBLIC_KEY / MP_ACCESS_TOKEN / MP_ENV / MP_WEBHOOK_SECRET
# Prefira os nomes MERCADOPAGO_* acima.
# -----------------------------------------------------------------------------
